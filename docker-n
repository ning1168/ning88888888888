show_status(){
  echo "============================================================"
  echo "当前状态"
  echo "============================================================"
  echo "系统：$OS_NAME"
  echo

  echo "【Docker】"
  if command -v docker >/dev/null 2>&1; then
    echo "版本：$(docker --version)"
    echo "Compose：$(docker compose version 2>/dev/null || echo 未安装)"
    echo "容器："
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  else
    echo "未安装"
  fi

  echo
  echo "【Nginx】"
  if command -v nginx >/dev/null 2>&1; then
    echo "版本：$(nginx -v 2>&1)"
    echo "服务：$(systemctl is-active nginx 2>/dev/null || echo 未知)"
    if nginx -t >/tmp/nginx_check.log 2>&1; then
      echo "配置：通过"
    else
      echo "配置：失败"
      cat /tmp/nginx_check.log
    fi
    echo "启用站点："
    nginx_sites_enabled || true
  else
    echo "未安装"
  fi

  echo
  echo "【HTTPS】"
  if command -v certbot >/dev/null 2>&1; then
    certbot --version || true
  else
    echo "Certbot 未安装"
  fi

  echo
  echo "默认 Docker 目录：$LAST_BASE"
}

show_commands(){
cat <<'EOF'
Docker:
  docker ps
  docker logs -f 容器名
  docker restart 容器名
  docker exec -it 容器名 sh

Compose:
  cd 项目目录
  docker compose up -d          # 启动/应用 docker-compose.yml 改动
  docker compose restart        # 只重启容器，不应用端口/挂载改动
  docker compose pull           # 拉取新镜像
  docker compose logs -f        # 查看日志
  docker compose down           # 停止并删除容器，不删挂载数据

Nginx:
  nginx -t
  systemctl reload nginx
  systemctl status nginx

HTTPS:
  certbot --nginx -d 域名
  certbot certificates
  certbot renew --dry-run
EOF
}

