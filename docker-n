#!/usr/bin/env bash
# Docker + Nginx 小白菜单工具箱 v4
# 默认 Docker 项目目录：/docker

set -e

RED="\033[31m"; GREEN="\033[32m"; YELLOW="\033[33m"; BLUE="\033[34m"; NC="\033[0m"
VERSION="2026.05.01-v4"
CONF_DIR="/root/.docker-nginx-tool"
CONF_FILE="$CONF_DIR/config"
DEFAULT_BASE="/docker"
LAST_BASE="$DEFAULT_BASE"

log(){ echo -e "${GREEN}[成功]${NC} $1"; }
info(){ echo -e "${BLUE}[提示]${NC} $1"; }
warn(){ echo -e "${YELLOW}[注意]${NC} $1"; }
err(){ echo -e "${RED}[错误]${NC} $1"; }

need_root(){ [ "$(id -u)" -eq 0 ] || { err "请用 root 运行：sudo bash tool.sh"; exit 1; }; }

detect_os(){
  [ -f /etc/os-release ] || { err "无法识别系统"; exit 1; }
  . /etc/os-release
  OS_ID="$ID"; OS_CODENAME="$VERSION_CODENAME"; OS_NAME="$PRETTY_NAME"
  if [ "$OS_ID" != "debian" ] && [ "$OS_ID" != "ubuntu" ]; then
    err "仅适配 Debian / Ubuntu，当前：$OS_ID"; exit 1
  fi
}

load_conf(){
  mkdir -p "$CONF_DIR"
  [ -f "$CONF_FILE" ] && . "$CONF_FILE" || true
  LAST_BASE="${LAST_BASE:-$DEFAULT_BASE}"
}
save_conf(){
  mkdir -p "$CONF_DIR"
  echo "LAST_BASE=\"$LAST_BASE\"" > "$CONF_FILE"
}
pause(){ echo; read -rp "按回车返回菜单..."; }

ask_yn(){
  local q="$1" d="$2" a
  while true; do
    if [ "$d" = "y" ]; then read -rp "$q [Y/n]: " a; a="${a:-Y}"
    else read -rp "$q [y/N]: " a; a="${a:-N}"; fi
    case "$a" in y|Y|yes|YES|Yes) return 0;; n|N|no|NO|No) return 1;; *) echo "请输入 y/n 或 yes/no";; esac
  done
}

safe_name(){ echo "$1" | grep -Eq '^[a-zA-Z0-9._-]+$'; }
valid_port(){ echo "$1" | grep -Eq '^[0-9]+$' && [ "$1" -ge 1 ] && [ "$1" -le 65535 ]; }

handle_file(){
  local file="$1"
  [ ! -f "$file" ] && return 0
  warn "文件已存在：$file"
  echo "1) 直接覆盖"
  echo "2) 备份后覆盖"
  echo "3) 取消"
  read -rp "请选择 1/2/3（默认 3）: " c
  c="${c:-3}"
  case "$c" in
    1) return 0;;
    2) cp "$file" "${file}.bak.$(date +%Y%m%d-%H%M%S)"; warn "已备份旧文件"; return 0;;
    *) return 1;;
  esac
}

install_base_tools(){
  info "安装基础工具..."
  apt update
  apt install -y ca-certificates curl wget gnupg lsb-release nano vim git
  log "基础工具完成"
}

install_docker(){
  detect_os
  if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
    warn "Docker 和 Compose 插件已安装，跳过"
    docker --version; docker compose version; return
  fi
  install_base_tools
  if ! command -v docker >/dev/null 2>&1; then
    info "安装 Docker 官方源..."
    apt remove -y docker.io docker-compose docker-doc podman-docker containerd runc 2>/dev/null || true
    install -m 0755 -d /etc/apt/keyrings
    if [ ! -f /etc/apt/keyrings/docker.asc ]; then
      curl -fsSL "https://download.docker.com/linux/${OS_ID}/gpg" -o /etc/apt/keyrings/docker.asc
      chmod a+r /etc/apt/keyrings/docker.asc
    fi
    cat > /etc/apt/sources.list.d/docker.sources <<EOF
Types: deb
URIs: https://download.docker.com/linux/${OS_ID}
Suites: ${OS_CODENAME}
Components: stable
Architectures: $(dpkg --print-architecture)
Signed-By: /etc/apt/keyrings/docker.asc
EOF
    apt update
    apt install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
    systemctl enable docker
    systemctl start docker
    log "Docker 安装完成"
  fi
  if ! docker compose version >/dev/null 2>&1; then apt install -y docker-compose-plugin; fi
  docker --version; docker compose version
}

install_nginx(){
  if command -v nginx >/dev/null 2>&1; then
    warn "Nginx 已安装，跳过"; nginx -v
  else
    install_base_tools
    apt install -y nginx
    log "Nginx 安装完成"
  fi
  systemctl enable nginx
  systemctl start nginx
  nginx -t
}

install_all(){ install_docker; install_nginx; log "基础环境完成：Docker + Compose 插件 + Nginx"; }

create_docker_template(){
  info "创建 Docker 服务目录和 docker-compose.yml"
  read -rp "服务名/文件夹名（默认 myapp）: " name; name="${name:-myapp}"
  while ! safe_name "$name"; do err "只能用英文、数字、横杠、下划线、点"; read -rp "重新输入服务名: " name; done
  read -rp "统一存放目录（默认 $LAST_BASE）: " base; base="${base:-$LAST_BASE}"
  LAST_BASE="$base"; save_conf
  dir="$base/$name"; file="$dir/docker-compose.yml"
  mkdir -p "$dir"
  handle_file "$file" || return
  echo "模板类型："
  echo "1) 通用模板"
  echo "2) S-UI 示例模板"
  echo "3) 极简模板"
  read -rp "选择（默认 1）: " t; t="${t:-1}"
  case "$t" in
    2)
cat > "$file" <<'EOF'
services:
  s-ui:
    image: alireza7/s-ui:latest
    container_name: s-ui
    restart: unless-stopped
    ports:
      - "127.0.0.1:2095:2095"
      - "127.0.0.1:2096:2096"
      # 如节点需要公网端口，可取消下一行注释
      # - "8443:8443"
    volumes:
      - ./db:/app/db
      - ./cert:/app/cert
EOF
      ;;
    3)
cat > "$file" <<EOF
services:
  $name:
    image: 请改成你的镜像名:latest
    container_name: $name
    restart: unless-stopped
EOF
      ;;
    *)
cat > "$file" <<EOF
services:
  $name:
    image: 请改成你的镜像名:latest
    container_name: $name
    restart: unless-stopped
    ports:
      # 面板类推荐 127.0.0.1，只让 Nginx 转发
      - "127.0.0.1:8080:8080"
    volumes:
      - ./data:/app/data
EOF
      ;;
  esac
  log "已创建：$file"
  echo "编辑：nano $file"
  echo "启动：cd $dir && docker compose up -d"
}

create_nginx_proxy(){
  command -v nginx >/dev/null 2>&1 || { err "未安装 Nginx，请先安装"; return; }
  read -rp "Nginx 配置名（默认 myapp）: " name; name="${name:-myapp}"
  while ! safe_name "$name"; do err "只能用英文、数字、横杠、下划线、点"; read -rp "重新输入配置名: " name; done
  read -rp "域名（例 app.example.com）: " domain
  [ -z "$domain" ] && { err "域名不能为空"; return; }
  read -rp "反代本机端口（例 2095）: " port
  while ! valid_port "$port"; do err "端口必须是 1-65535"; read -rp "重新输入端口: " port; done
  file="/etc/nginx/sites-available/$name"
  handle_file "$file" || return
cat > "$file" <<EOF
server {
    listen 80;
    server_name $domain;

    location / {
        proxy_pass http://127.0.0.1:$port;

        proxy_http_version 1.1;

        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;

        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";

        send_timeout 10800;
        proxy_read_timeout 10800;
        proxy_send_timeout 10800;
    }
}
EOF
  ln -sf "$file" "/etc/nginx/sites-enabled/$name"
  if [ -e /etc/nginx/sites-enabled/default ]; then
    ask_yn "检测到默认站点 default，是否删除" "y" && rm -f /etc/nginx/sites-enabled/default
  fi
  nginx -t
  systemctl reload nginx
  log "已创建反代：http://$domain -> 127.0.0.1:$port"
  echo "配置文件：$file"
}

certbot_issue(){
  command -v nginx >/dev/null 2>&1 || { err "请先安装 Nginx"; return; }
  if ! command -v certbot >/dev/null 2>&1; then
    apt update; apt install -y certbot python3-certbot-nginx
  fi
  read -rp "请输入申请证书的域名: " domain
  [ -z "$domain" ] && { err "域名不能为空"; return; }
  certbot --nginx -d "$domain"
  echo "测试续期：certbot renew --dry-run"
}

find_compose_dirs(){
  find "$LAST_BASE" /opt/docker-apps /app -name docker-compose.yml -o -name compose.yml 2>/dev/null | sort -u
}

update_one_service(){
  info "更新某个 Docker Compose 服务"
  mapfile -t files < <(find_compose_dirs)
  if [ "${#files[@]}" -eq 0 ]; then
    warn "没有找到 docker-compose.yml"; read -rp "手动输入项目目录: " dir
  else
    echo "找到以下项目："
    for i in "${!files[@]}"; do echo "$((i+1))) ${files[$i]}"; done
    echo "0) 手动输入目录"
    read -rp "请选择项目编号: " n
    if [ "$n" = "0" ]; then read -rp "手动输入项目目录: " dir
    else idx=$((n-1)); dir="$(dirname "${files[$idx]}")"; fi
  fi
  [ -z "$dir" ] && return
  [ ! -f "$dir/docker-compose.yml" ] && [ ! -f "$dir/compose.yml" ] && { err "该目录没有 compose 文件"; return; }
  echo "即将更新：$dir"; ask_yn "确认更新？" "y" || return
  cd "$dir"
  docker compose pull
  docker compose up -d
  ask_yn "是否清理旧镜像？" "n" && docker image prune -f
  log "更新完成：$dir"
}

update_all_services(){
  info "一键升级所有 Docker Compose 项目"
  warn "会依次执行 docker compose pull && docker compose up -d，执行前会让你确认"
  mapfile -t files < <(find_compose_dirs)
  [ "${#files[@]}" -eq 0 ] && { warn "没有找到 docker-compose.yml"; return; }
  echo "将更新以下项目："
  for f in "${files[@]}"; do echo "- $(dirname "$f")"; done
  ask_yn "确认全部更新？" "n" || return
  for f in "${files[@]}"; do
    dir="$(dirname "$f")"
    echo; info "更新：$dir"
    cd "$dir"
    docker compose pull
    docker compose up -d
  done
  ask_yn "是否清理所有旧镜像？" "n" && docker image prune -f
  log "全部更新完成"
}

disable_or_delete_nginx_site(){
  command -v nginx >/dev/null 2>&1 || { err "未安装 Nginx"; return; }
  echo "已启用的 Nginx 站点："
  mapfile -t sites < <(ls /etc/nginx/sites-enabled 2>/dev/null || true)
  [ "${#sites[@]}" -eq 0 ] && { warn "没有启用的站点"; return; }
  for i in "${!sites[@]}"; do echo "$((i+1))) ${sites[$i]}"; done
  read -rp "请选择站点编号: " n
  idx=$((n-1)); site="${sites[$idx]}"
  [ -z "$site" ] && { err "选择无效"; return; }
  echo "选择站点：$site"
  echo "1) 禁用站点（只删除 sites-enabled 链接，推荐）"
  echo "2) 删除配置文件（删除 sites-available 配置）"
  echo "3) 取消"
  read -rp "请选择 1/2/3: " c
  case "$c" in
    1) rm -f "/etc/nginx/sites-enabled/$site"; nginx -t; systemctl reload nginx; log "已禁用站点：$site";;
    2) rm -f "/etc/nginx/sites-enabled/$site"; rm -f "/etc/nginx/sites-available/$site"; nginx -t; systemctl reload nginx; log "已删除站点配置：$site";;
    *) warn "已取消";;
  esac
}

show_status(){
  echo "============================================================"
  echo "当前状态"
  echo "============================================================"
  echo "系统：$(. /etc/os-release && echo "$PRETTY_NAME")"
  echo
  echo "【Docker】"
  if command -v docker >/dev/null 2>&1; then
    echo "Docker 版本：$(docker --version)"
    echo "Compose 插件：$(docker compose version 2>/dev/null || echo 未安装)"
    echo "容器列表："
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  else echo "Docker：未安装"; fi
  echo
  echo "【Nginx】"
  if command -v nginx >/dev/null 2>&1; then
    echo "Nginx 版本：$(nginx -v 2>&1)"
    echo "服务状态：$(systemctl is-active nginx 2>/dev/null || echo 未知)"
    if nginx -t >/tmp/nginx_check.log 2>&1; then echo "配置检查：通过"; else echo "配置检查：失败"; cat /tmp/nginx_check.log; fi
    echo "启用站点："; ls -l /etc/nginx/sites-enabled 2>/dev/null || true
  else echo "Nginx：未安装"; fi
  echo
  echo "【Certbot】"
  command -v certbot >/dev/null 2>&1 && certbot --version || echo "Certbot：未安装"
  echo
  echo "默认 Docker 项目目录：$LAST_BASE"
}

show_commands(){
cat <<'EOF'
Docker:
  docker ps
  docker logs -f 容器名
  docker restart 容器名
  docker exec -it 容器名 sh

Compose:
  cd 项目目录
  docker compose pull
  docker compose up -d
  docker compose logs -f

Nginx:
  nginx -t
  systemctl reload nginx

证书:
  certbot --nginx -d 域名
  certbot renew --dry-run
EOF
}

menu(){
  while true; do
    clear
    echo "============================================================"
    echo "Docker + Nginx 小白菜单工具箱 $VERSION"
    echo "默认 Docker 目录：$LAST_BASE"
    echo "============================================================"
    echo "1) 安装基础环境（Docker + Compose 插件 + Nginx）"
    echo "2) 只安装/检测 Docker + Compose 插件"
    echo "3) 只安装/检测 Nginx"
    echo "4) 创建 Docker 服务目录和 compose 模板"
    echo "5) 创建 Nginx 通用反向代理"
    echo "6) 安装 Certbot 并申请 HTTPS"
    echo "7) 查看当前状态"
    echo "8) 查看常用命令"
    echo "9) 一键升级所有 Compose 项目"
    echo "10) 更新某个 Compose 服务"
    echo "11) 禁用/删除 Nginx 站点"
    echo "0) 退出"
    echo
    read -rp "请选择功能编号: " c
    case "$c" in
      1) install_all; pause;;
      2) install_docker; pause;;
      3) install_nginx; pause;;
      4) create_docker_template; pause;;
      5) create_nginx_proxy; pause;;
      6) certbot_issue; pause;;
      7) show_status; pause;;
      8) show_commands; pause;;
      9) update_all_services; pause;;
      10) update_one_service; pause;;
      11) disable_or_delete_nginx_site; pause;;
      0) exit 0;;
      *) echo "无效选项"; sleep 1;;
    esac
  done
}

main(){ need_root; detect_os; load_conf; menu; }
main "$@"
