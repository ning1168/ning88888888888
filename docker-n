#!/usr/bin/env bash
# ============================================================
# Docker + Nginx + HTTPS 小白工具箱 v7
# 适合：Debian / Ubuntu
#
# 修复重点：
# - 取消/回车不再退出脚本
# - Docker 项目选择、日志、更新、停止、重启逻辑修复
# - Nginx 禁用/删除选择逻辑修复
# - Nginx 删除会同时处理 sites-enabled 和 sites-available
# - 已有配置只提供：覆盖 / 取消，不再生成备份文件
# - 新增 Nginx 空模板
# - HTTPS 证书独立管理
#
# 默认 Docker 项目目录：/docker
# 配置记忆文件：/root/.docker-nginx-tool/config
# ============================================================

# 交互脚本不使用 set -e，避免用户取消/回车时直接退出整个脚本
set -o pipefail

RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
BLUE="\033[34m"
NC="\033[0m"

VERSION="2026.05.01-v7"
CONF_DIR="/root/.docker-nginx-tool"
CONF_FILE="$CONF_DIR/config"
DEFAULT_BASE="/docker"
LAST_BASE="$DEFAULT_BASE"

OS_ID=""
OS_CODENAME=""
OS_NAME="未知系统"
SELECTED_DIR=""
SELECTED_SITE=""

log(){ echo -e "${GREEN}[成功]${NC} $1"; }
info(){ echo -e "${BLUE}[提示]${NC} $1"; }
warn(){ echo -e "${YELLOW}[注意]${NC} $1"; }
err(){ echo -e "${RED}[错误]${NC} $1"; }

need_root(){
  if [ "$(id -u)" -ne 0 ]; then
    err "请使用 root 运行，例如：sudo bash tool.sh"
    exit 1
  fi
}

detect_os(){
  if [ ! -f /etc/os-release ]; then
    err "无法识别系统：找不到 /etc/os-release"
    exit 1
  fi

  . /etc/os-release
  OS_ID="${ID:-}"
  OS_CODENAME="${VERSION_CODENAME:-}"
  OS_NAME="${PRETTY_NAME:-未知系统}"

  if [ "$OS_ID" != "debian" ] && [ "$OS_ID" != "ubuntu" ]; then
    err "仅适配 Debian / Ubuntu，当前系统：$OS_ID"
    exit 1
  fi
}

load_conf(){
  mkdir -p "$CONF_DIR"
  if [ -f "$CONF_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONF_FILE" 2>/dev/null || true
  fi
  LAST_BASE="${LAST_BASE:-$DEFAULT_BASE}"
}

save_conf(){
  mkdir -p "$CONF_DIR"
  cat > "$CONF_FILE" <<EOF
LAST_BASE="$LAST_BASE"
EOF
}

pause(){
  echo
  read -rp "按回车返回..."
}

ask_yn(){
  local q="$1"
  local d="$2"
  local a

  while true; do
    if [ "$d" = "y" ]; then
      read -rp "$q [Y/n]: " a
      a="${a:-Y}"
    else
      read -rp "$q [y/N]: " a
      a="${a:-N}"
    fi

    case "$a" in
      y|Y|yes|YES|Yes) return 0 ;;
      n|N|no|NO|No) return 1 ;;
      *) echo "请输入 y/n 或 yes/no" ;;
    esac
  done
}

safe_name(){
  echo "$1" | grep -Eq '^[a-zA-Z0-9._-]+$'
}

valid_port(){
  echo "$1" | grep -Eq '^[0-9]+$' && [ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

confirm_overwrite_file(){
  local file="$1"

  if [ ! -e "$file" ]; then
    return 0
  fi

  warn "文件已存在：$file"
  echo "1) 直接覆盖"
  echo "0) 取消"
  read -rp "请选择（默认 0 取消）: " c
  c="${c:-0}"

  case "$c" in
    1)
      rm -f "$file"
      return 0
      ;;
    *)
      warn "已取消"
      return 1
      ;;
  esac
}

install_base_tools(){
  info "检查/安装基础工具..."
  apt update
  apt install -y ca-certificates curl wget gnupg lsb-release nano vim git
  log "基础工具已就绪"
}

install_docker(){
  detect_os

  if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
    warn "Docker 和 Compose 插件已安装，跳过"
    docker --version
    docker compose version
    return 0
  fi

  install_base_tools

  if ! command -v docker >/dev/null 2>&1; then
    info "安装 Docker 官方源..."

    apt remove -y docker.io docker-compose docker-doc podman-docker containerd runc 2>/dev/null || true

    install -m 0755 -d /etc/apt/keyrings

    if [ ! -f /etc/apt/keyrings/docker.asc ]; then
      curl -fsSL "https://download.docker.com/linux/${OS_ID}/gpg" -o /etc/apt/keyrings/docker.asc
      chmod a+r /etc/apt/keyrings/docker.asc
    fi

    cat > /etc/apt/sources.list.d/docker.sources <<EOF
Types: deb
URIs: https://download.docker.com/linux/${OS_ID}
Suites: ${OS_CODENAME}
Components: stable
Architectures: $(dpkg --print-architecture)
Signed-By: /etc/apt/keyrings/docker.asc
EOF

    apt update
    apt install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

    systemctl enable docker
    systemctl start docker

    log "Docker 安装完成"
  fi

  if ! docker compose version >/dev/null 2>&1; then
    apt install -y docker-compose-plugin
  fi

  docker --version
  docker compose version
}

install_nginx(){
  if command -v nginx >/dev/null 2>&1; then
    warn "Nginx 已安装，跳过"
    nginx -v
  else
    install_base_tools
    apt install -y nginx
    log "Nginx 安装完成"
  fi

  systemctl enable nginx
  systemctl start nginx
  test_reload_nginx
}

install_all(){
  install_docker
  install_nginx
  log "基础环境完成"
}

# ----------------------------
# Docker / Compose
# ----------------------------

find_compose_files(){
  local dirs=()
  dirs+=("$LAST_BASE")
  dirs+=("/docker")
  dirs+=("/opt/docker-apps")
  dirs+=("/app")

  for d in "${dirs[@]}"; do
    [ -d "$d" ] || continue
    find "$d" \( -name docker-compose.yml -o -name compose.yml \) 2>/dev/null
  done | sort -u
}

show_compose_projects(){
  mapfile -t files < <(find_compose_files)

  if [ "${#files[@]}" -eq 0 ]; then
    warn "没有找到 Compose 项目"
    echo "默认搜索目录：$LAST_BASE /docker /opt/docker-apps /app"
    return 0
  fi

  echo "Compose 项目列表："
  for i in "${!files[@]}"; do
    echo "$((i+1))) $(dirname "${files[$i]}")"
  done
}

select_compose_dir(){
  SELECTED_DIR=""
  mapfile -t files < <(find_compose_files)

  if [ "${#files[@]}" -eq 0 ]; then
    warn "没有自动找到 Compose 文件"
    read -rp "手动输入项目目录（回车取消）: " manual_dir
    if [ -z "$manual_dir" ]; then
      return 1
    fi

    if [ ! -f "$manual_dir/docker-compose.yml" ] && [ ! -f "$manual_dir/compose.yml" ]; then
      err "该目录没有 docker-compose.yml 或 compose.yml"
      return 1
    fi

    SELECTED_DIR="$manual_dir"
    return 0
  fi

  echo "请选择 Compose 项目："
  for i in "${!files[@]}"; do
    echo "$((i+1))) $(dirname "${files[$i]}")"
  done
  echo "m) 手动输入目录"
  echo "0) 取消"

  read -rp "请选择项目编号（默认 0 取消）: " n
  n="${n:-0}"

  if [ "$n" = "0" ]; then
    return 1
  fi

  if [ "$n" = "m" ] || [ "$n" = "M" ]; then
    read -rp "手动输入项目目录（回车取消）: " manual_dir
    if [ -z "$manual_dir" ]; then
      return 1
    fi

    if [ ! -f "$manual_dir/docker-compose.yml" ] && [ ! -f "$manual_dir/compose.yml" ]; then
      err "该目录没有 docker-compose.yml 或 compose.yml"
      return 1
    fi

    SELECTED_DIR="$manual_dir"
    return 0
  fi

  if ! echo "$n" | grep -Eq '^[0-9]+$'; then
    err "选择无效"
    return 1
  fi

  idx=$((n-1))
  if [ "$idx" -lt 0 ] || [ "$idx" -ge "${#files[@]}" ]; then
    err "选择无效"
    return 1
  fi

  SELECTED_DIR="$(dirname "${files[$idx]}")"
  return 0
}

create_docker_template(){
  info "创建 Docker 服务目录和 compose 模板"

  read -rp "服务名/文件夹名（默认 myapp，回车使用默认）: " name
  name="${name:-myapp}"

  while ! safe_name "$name"; do
    err "只能用英文、数字、横杠、下划线、点"
    read -rp "重新输入服务名（回车取消）: " name
    [ -z "$name" ] && return 0
  done

  read -rp "统一存放目录（默认 $LAST_BASE）: " base
  base="${base:-$LAST_BASE}"
  LAST_BASE="$base"
  save_conf

  dir="$base/$name"
  file="$dir/docker-compose.yml"

  mkdir -p "$dir"

  confirm_overwrite_file "$file" || return 0

  echo
  echo "模板类型："
  echo "1) 通用模板"
  echo "2) S-UI 示例"
  echo "3) 极简模板"
  echo "0) 取消"
  read -rp "选择（默认 1）: " t
  t="${t:-1}"

  case "$t" in
    0)
      warn "已取消"
      return 0
      ;;
    2)
cat > "$file" <<'EOF'
services:
  s-ui:
    image: alireza7/s-ui:latest
    container_name: s-ui
    restart: unless-stopped
    ports:
      # 面板端口：只允许本机访问，然后用 Nginx 反代
      - "127.0.0.1:2095:2095"

      # 订阅端口：只允许本机访问，然后用 Nginx 反代或按需使用
      - "127.0.0.1:2096:2096"

      # 节点端口示例：如需要公网访问再打开
      # - "8443:8443"
    volumes:
      - ./db:/app/db
      - ./cert:/app/cert
EOF
      ;;
    3)
cat > "$file" <<EOF
services:
  $name:
    image: 请改成你的镜像名:latest
    container_name: $name
    restart: unless-stopped
EOF
      ;;
    *)
cat > "$file" <<EOF
services:
  $name:
    image: 请改成你的镜像名:latest
    container_name: $name
    restart: unless-stopped
    ports:
      # 面板类推荐 127.0.0.1，只让 Nginx 转发
      - "127.0.0.1:8080:8080"
    volumes:
      - ./data:/app/data
EOF
      ;;
  esac

  log "已创建：$file"
  echo "编辑：nano $file"
  echo "应用配置/启动：cd $dir && docker compose up -d"
}

compose_apply(){
  select_compose_dir || return 0
  cd "$SELECTED_DIR" || return 0

  info "执行 docker compose up -d"
  docker compose up -d
  log "已启动/应用配置：$SELECTED_DIR"
}

compose_stop(){
  select_compose_dir || return 0
  cd "$SELECTED_DIR" || return 0

  echo "将停止项目：$SELECTED_DIR"
  ask_yn "确认停止？" "n" || return 0

  docker compose down
  log "已停止：$SELECTED_DIR"
}

compose_restart(){
  select_compose_dir || return 0
  cd "$SELECTED_DIR" || return 0

  warn "docker compose restart 只重启容器，不会应用 docker-compose.yml 里的端口/挂载改动"
  echo "1) 应用配置并重建（推荐，docker compose up -d）"
  echo "2) 只重启容器（docker compose restart）"
  echo "0) 取消"
  read -rp "请选择（默认 1）: " c
  c="${c:-1}"

  case "$c" in
    1)
      docker compose up -d
      log "已应用配置并重建：$SELECTED_DIR"
      ;;
    2)
      docker compose restart
      log "已重启容器：$SELECTED_DIR"
      ;;
    *)
      warn "已取消"
      ;;
  esac
}

compose_logs(){
  select_compose_dir || return 0
  cd "$SELECTED_DIR" || return 0

  echo "查看日志：$SELECTED_DIR"
  echo "按 Ctrl+C 退出日志"
  docker compose logs -f
}

update_one_service(){
  info "更新某个 Compose 项目"

  select_compose_dir || return 0

  echo "即将更新：$SELECTED_DIR"
  ask_yn "确认更新？" "y" || return 0

  cd "$SELECTED_DIR" || return 0
  docker compose pull
  docker compose up -d

  ask_yn "是否清理旧镜像？" "n" && docker image prune -f

  log "更新完成：$SELECTED_DIR"
}

update_all_services(){
  info "一键升级所有 Compose 项目"
  warn "会执行 docker compose pull && docker compose up -d"

  mapfile -t files < <(find_compose_files)

  if [ "${#files[@]}" -eq 0 ]; then
    warn "没有找到 Compose 文件"
    return 0
  fi

  echo "将更新以下项目："
  for f in "${files[@]}"; do
    echo "- $(dirname "$f")"
  done

  ask_yn "确认全部更新？" "n" || return 0

  for f in "${files[@]}"; do
    dir="$(dirname "$f")"
    echo
    info "更新：$dir"
    cd "$dir" || continue
    docker compose pull
    docker compose up -d
  done

  ask_yn "是否清理所有旧镜像？" "n" && docker image prune -f

  log "全部更新完成"
}

docker_prune(){
  warn "清理旧镜像/无用资源可以释放空间，但不会删除正在运行的容器"
  echo "1) 只清理无用镜像（推荐）"
  echo "2) 清理无用镜像、停止容器、无用网络、构建缓存"
  echo "0) 取消"
  read -rp "请选择（默认 0 取消）: " c
  c="${c:-0}"

  case "$c" in
    1)
      docker image prune -f
      ;;
    2)
      ask_yn "确认执行 docker system prune？" "n" || return 0
      docker system prune -f
      ;;
    *)
      warn "已取消"
      return 0
      ;;
  esac

  log "清理完成"
}

docker_uninstall(){
  warn "这是危险操作：卸载 Docker 会影响所有容器服务"
  echo "1) 卸载 Docker（保留项目目录和 Docker 数据）"
  echo "2) 完全卸载 Docker（含 /var/lib/docker 系统数据）"
  echo "0) 取消"
  read -rp "请选择（默认 0 取消）: " c
  c="${c:-0}"

  case "$c" in
    1)
      ask_yn "确认卸载 Docker？" "n" || return 0
      apt remove -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin || true
      log "Docker 已卸载，项目目录未删除，/var/lib/docker 尽量保留"
      ;;
    2)
      ask_yn "确认完全卸载 Docker？这会删除容器/镜像/卷数据" "n" || return 0
      apt remove -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin || true
      rm -rf /var/lib/docker /var/lib/containerd
      log "Docker 已完全卸载，系统 Docker 数据已删除"
      ;;
    *)
      warn "已取消"
      ;;
  esac
}

# ----------------------------
# Nginx
# ----------------------------

nginx_sites_available(){
  if [ -d /etc/nginx/sites-available ]; then
    find /etc/nginx/sites-available -maxdepth 1 -type f -printf '%f\n' 2>/dev/null | sort -u
  fi
}

nginx_sites_enabled(){
  if [ -d /etc/nginx/sites-enabled ]; then
    find /etc/nginx/sites-enabled -maxdepth 1 \( -type f -o -type l \) -printf '%f\n' 2>/dev/null | sort -u
  fi
}

nginx_sites_all(){
  {
    nginx_sites_available
    nginx_sites_enabled
  } | sort -u
}

test_reload_nginx(){
  if nginx -t; then
    systemctl reload nginx 2>/dev/null || systemctl restart nginx
    log "Nginx 配置检查通过并已重载"
  else
    err "Nginx 配置检查失败，请检查配置文件"
  fi
}

create_nginx_proxy(){
  command -v nginx >/dev/null 2>&1 || { err "未安装 Nginx，请先安装"; return 0; }

  read -rp "Nginx 配置名（默认 myapp）: " name
  name="${name:-myapp}"

  while ! safe_name "$name"; do
    err "只能用英文、数字、横杠、下划线、点"
    read -rp "重新输入配置名（回车取消）: " name
    [ -z "$name" ] && return 0
  done

  read -rp "域名（例 app.example.com，回车取消）: " domain
  [ -z "$domain" ] && return 0

  read -rp "反代本机端口（例 2095，回车取消）: " port
  [ -z "$port" ] && return 0

  while ! valid_port "$port"; do
    err "端口必须是 1-65535"
    read -rp "重新输入端口（回车取消）: " port
    [ -z "$port" ] && return 0
  done

  mkdir -p /etc/nginx/sites-available /etc/nginx/sites-enabled

  file="/etc/nginx/sites-available/$name"
  enabled="/etc/nginx/sites-enabled/$name"

  confirm_overwrite_file "$file" || return 0
  rm -f "$enabled"

cat > "$file" <<EOF
server {
    listen 80;
    server_name $domain;

    location / {
        proxy_pass http://127.0.0.1:$port;

        proxy_http_version 1.1;

        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;

        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";

        send_timeout 10800;
        proxy_read_timeout 10800;
        proxy_send_timeout 10800;
    }
}
EOF

  ln -s "$file" "$enabled"

  if [ -e /etc/nginx/sites-enabled/default ]; then
    ask_yn "检测到默认站点 default，是否删除" "y" && rm -f /etc/nginx/sites-enabled/default
  fi

  test_reload_nginx

  log "已创建反代：http://$domain -> 127.0.0.1:$port"
  echo "配置文件：$file"
  echo "启用链接：$enabled"
}

create_nginx_blank_template(){
  command -v nginx >/dev/null 2>&1 || { err "未安装 Nginx，请先安装"; return 0; }

  read -rp "空模板名称（默认 blank，回车使用默认）: " name
  name="${name:-blank}"

  while ! safe_name "$name"; do
    err "只能用英文、数字、横杠、下划线、点"
    read -rp "重新输入名称（回车取消）: " name
    [ -z "$name" ] && return 0
  done

  mkdir -p /etc/nginx/sites-available

  file="/etc/nginx/sites-available/$name"

  confirm_overwrite_file "$file" || return 0

cat > "$file" <<'EOF'
# Nginx 空模板
# 默认只保存在 sites-available，不自动启用。
# 编辑完成后，可以在菜单里选择“启用站点”。
#
# 示例：
#
# server {
#     listen 80;
#     server_name example.com;
#
#     location / {
#         proxy_pass http://127.0.0.1:8080;
#         proxy_http_version 1.1;
#
#         proxy_set_header Host $host;
#         proxy_set_header X-Real-IP $remote_addr;
#         proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#         proxy_set_header X-Forwarded-Proto $scheme;
#
#         proxy_set_header Upgrade $http_upgrade;
#         proxy_set_header Connection "upgrade";
#     }
# }
EOF

  log "已创建空模板：$file"
  echo "编辑：nano $file"
  echo "启用：Nginx 管理 -> 启用站点"
}

list_nginx_sites(){
  echo "已启用站点（sites-enabled）："
  nginx_sites_enabled || true
  echo
  echo "可用配置（sites-available）："
  nginx_sites_available || true
}

select_nginx_enabled_site(){
  SELECTED_SITE=""
  mapfile -t sites < <(nginx_sites_enabled)

  if [ "${#sites[@]}" -eq 0 ]; then
    warn "没有启用的站点"
    return 1
  fi

  echo "已启用站点："
  for i in "${!sites[@]}"; do
    echo "$((i+1))) ${sites[$i]}"
  done
  echo "0) 取消"

  read -rp "请选择站点编号（默认 0 取消）: " n
  n="${n:-0}"

  [ "$n" = "0" ] && return 1

  if ! echo "$n" | grep -Eq '^[0-9]+$'; then
    err "选择无效"
    return 1
  fi

  idx=$((n-1))
  if [ "$idx" -lt 0 ] || [ "$idx" -ge "${#sites[@]}" ]; then
    err "选择无效"
    return 1
  fi

  SELECTED_SITE="${sites[$idx]}"
  return 0
}

select_nginx_available_site(){
  SELECTED_SITE=""
  mapfile -t sites < <(nginx_sites_available)

  if [ "${#sites[@]}" -eq 0 ]; then
    warn "没有可用配置"
    return 1
  fi

  echo "可用配置："
  for i in "${!sites[@]}"; do
    echo "$((i+1))) ${sites[$i]}"
  done
  echo "0) 取消"

  read -rp "请选择站点编号（默认 0 取消）: " n
  n="${n:-0}"

  [ "$n" = "0" ] && return 1

  if ! echo "$n" | grep -Eq '^[0-9]+$'; then
    err "选择无效"
    return 1
  fi

  idx=$((n-1))
  if [ "$idx" -lt 0 ] || [ "$idx" -ge "${#sites[@]}" ]; then
    err "选择无效"
    return 1
  fi

  SELECTED_SITE="${sites[$idx]}"
  return 0
}

select_nginx_any_site(){
  SELECTED_SITE=""
  mapfile -t sites < <(nginx_sites_all)

  if [ "${#sites[@]}" -eq 0 ]; then
    warn "没有站点配置"
    return 1
  fi

  echo "站点配置："
  for i in "${!sites[@]}"; do
    enabled_mark=""
    if [ -e "/etc/nginx/sites-enabled/${sites[$i]}" ]; then
      enabled_mark=" [已启用]"
    fi
    echo "$((i+1))) ${sites[$i]}${enabled_mark}"
  done
  echo "0) 取消"

  read -rp "请选择站点编号（默认 0 取消）: " n
  n="${n:-0}"

  [ "$n" = "0" ] && return 1

  if ! echo "$n" | grep -Eq '^[0-9]+$'; then
    err "选择无效"
    return 1
  fi

  idx=$((n-1))
  if [ "$idx" -lt 0 ] || [ "$idx" -ge "${#sites[@]}" ]; then
    err "选择无效"
    return 1
  fi

  SELECTED_SITE="${sites[$idx]}"
  return 0
}

enable_nginx_site(){
  select_nginx_available_site || return 0

  file="/etc/nginx/sites-available/$SELECTED_SITE"
  enabled="/etc/nginx/sites-enabled/$SELECTED_SITE"

  if [ ! -f "$file" ]; then
    err "配置文件不存在：$file"
    return 0
  fi

  rm -f "$enabled"
  ln -s "$file" "$enabled"

  test_reload_nginx
  log "已启用站点：$SELECTED_SITE"
}

disable_nginx_site(){
  select_nginx_enabled_site || return 0

  echo "将禁用站点：$SELECTED_SITE"
  ask_yn "确认禁用？" "n" || return 0

  rm -f "/etc/nginx/sites-enabled/$SELECTED_SITE"

  test_reload_nginx
  log "已禁用：$SELECTED_SITE"
}

delete_nginx_site(){
  select_nginx_any_site || return 0

  echo "将删除站点：$SELECTED_SITE"
  warn "会删除 sites-enabled 链接和 sites-available 配置文件"
  ask_yn "确认删除？" "n" || return 0

  rm -f "/etc/nginx/sites-enabled/$SELECTED_SITE"
  rm -f "/etc/nginx/sites-available/$SELECTED_SITE"

  test_reload_nginx
  log "已删除：$SELECTED_SITE"
}

nginx_uninstall(){
  warn "这是危险操作：卸载 Nginx 会影响所有网站访问"
  echo "1) 卸载 Nginx（保留配置）"
  echo "2) 完全卸载 Nginx（含 /etc/nginx 配置）"
  echo "0) 取消"
  read -rp "请选择（默认 0 取消）: " c
  c="${c:-0}"

  case "$c" in
    1)
      ask_yn "确认卸载 Nginx？" "n" || return 0
      apt remove -y nginx nginx-common nginx-core || true
      log "Nginx 已卸载，配置尽量保留"
      ;;
    2)
      ask_yn "确认完全卸载 Nginx？这会删除 /etc/nginx" "n" || return 0
      apt purge -y nginx nginx-common nginx-core || true
      rm -rf /etc/nginx
      log "Nginx 已完全卸载，配置已删除"
      ;;
    *)
      warn "已取消"
      ;;
  esac
}

# ----------------------------
# HTTPS / Certbot
# ----------------------------

install_certbot(){
  if ! command -v certbot >/dev/null 2>&1; then
    apt update
    apt install -y certbot python3-certbot-nginx
    log "Certbot 已安装"
  else
    warn "Certbot 已安装"
    certbot --version || true
  fi
}

certbot_issue(){
  command -v nginx >/dev/null 2>&1 || { err "请先安装 Nginx"; return 0; }

  install_certbot

  read -rp "请输入申请证书的域名（回车取消）: " domain
  [ -z "$domain" ] && return 0

  certbot --nginx -d "$domain"
  echo "建议测试续期：certbot renew --dry-run"
}

certbot_list(){
  if ! command -v certbot >/dev/null 2>&1; then
    warn "Certbot 未安装"
    return 0
  fi

  certbot certificates
  echo
  echo "常见证书路径："
  echo "证书目录：/etc/letsencrypt/live/域名/"
  echo "fullchain：/etc/letsencrypt/live/域名/fullchain.pem"
  echo "privkey：/etc/letsencrypt/live/域名/privkey.pem"
}

certbot_test_renew(){
  if ! command -v certbot >/dev/null 2>&1; then
    warn "Certbot 未安装"
    return 0
  fi

  certbot renew --dry-run
}

certbot_force_renew(){
  if ! command -v certbot >/dev/null 2>&1; then
    warn "Certbot 未安装"
    return 0
  fi

  warn "强制续期一般不需要频繁执行"
  ask_yn "确认强制续期？" "n" || return 0

  certbot renew --force-renewal
}

certbot_delete(){
  if ! command -v certbot >/dev/null 2>&1; then
    warn "Certbot 未安装"
    return 0
  fi

  certbot certificates
  echo
  read -rp "请输入要删除证书的域名/证书名（回车取消）: " name
  [ -z "$name" ] && return 0

  warn "删除证书不会自动删除 Nginx 站点配置"
  ask_yn "确认删除该证书？" "n" || return 0

  certbot delete --cert-name "$name"
}

