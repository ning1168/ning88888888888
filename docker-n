#!/usr/bin/env bash
# ============================================================
# Docker + Docker Compose Plugin + Nginx 小白交互安装脚本
# 适合：Debian / Ubuntu
# ============================================================

set -e

RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
BLUE="\033[34m"
NC="\033[0m"

log() { echo -e "${GREEN}[成功]${NC} $1"; }
info() { echo -e "${BLUE}[提示]${NC} $1"; }
warn() { echo -e "${YELLOW}[注意]${NC} $1"; }
err() { echo -e "${RED}[错误]${NC} $1"; }

need_root() {
  if [ "$(id -u)" -ne 0 ]; then
    err "请使用 root 用户运行，或使用 sudo bash install.sh"
    exit 1
  fi
}

detect_os() {
  if [ ! -f /etc/os-release ]; then
    err "无法识别系统：找不到 /etc/os-release"
    exit 1
  fi

  . /etc/os-release
  OS_ID="${ID:-unknown}"
  OS_CODENAME="${VERSION_CODENAME:-}"

  if [ "$OS_ID" != "debian" ] && [ "$OS_ID" != "ubuntu" ]; then
    err "此脚本主要适配 Debian / Ubuntu，你当前系统是：$OS_ID"
    exit 1
  fi

  if [ -z "$OS_CODENAME" ]; then
    err "无法识别系统版本代号 VERSION_CODENAME"
    exit 1
  fi

  log "检测到系统：$PRETTY_NAME"
}

ask_yes_no() {
  local question="$1"
  local default="$2"
  local answer

  while true; do
    if [ "$default" = "y" ]; then
      read -rp "$question [Y/n]: " answer
      answer="${answer:-Y}"
    else
      read -rp "$question [y/N]: " answer
      answer="${answer:-N}"
    fi

    case "$answer" in
      y|Y|yes|YES) return 0 ;;
      n|N|no|NO) return 1 ;;
      *) echo "请输入 y 或 n" ;;
    esac
  done
}

safe_name() {
  local value="$1"
  if ! echo "$value" | grep -Eq '^[a-zA-Z0-9._-]+$'; then
    return 1
  fi
  return 0
}

install_base_tools() {
  info "更新 apt 软件源并安装基础工具..."
  apt update
  apt install -y ca-certificates curl wget gnupg lsb-release nano vim git ufw
  log "基础工具安装完成"
}

install_docker_repo() {
  if command -v docker >/dev/null 2>&1; then
    warn "检测到 Docker 已经安装，跳过 Docker 安装"
    docker --version || true
    return
  fi

  info "开始安装 Docker 官方 apt 仓库..."

  apt remove -y docker.io docker-compose docker-doc podman-docker containerd runc 2>/dev/null || true

  install -m 0755 -d /etc/apt/keyrings

  if [ ! -f /etc/apt/keyrings/docker.asc ]; then
    curl -fsSL "https://download.docker.com/linux/${OS_ID}/gpg" -o /etc/apt/keyrings/docker.asc
    chmod a+r /etc/apt/keyrings/docker.asc
    log "Docker GPG key 添加完成"
  else
    warn "Docker GPG key 已存在，跳过"
  fi

  cat > /etc/apt/sources.list.d/docker.sources <<EOF
Types: deb
URIs: https://download.docker.com/linux/${OS_ID}
Suites: ${OS_CODENAME}
Components: stable
Architectures: $(dpkg --print-architecture)
Signed-By: /etc/apt/keyrings/docker.asc
EOF

  apt update
  apt install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

  systemctl enable docker
  systemctl start docker

  log "Docker 安装完成"
  docker --version
  docker compose version
}

install_compose_plugin_if_missing() {
  if docker compose version >/dev/null 2>&1; then
    warn "检测到 Docker Compose 插件已经可用，跳过"
    docker compose version
  else
    info "安装 Docker Compose 插件..."
    apt update
    apt install -y docker-compose-plugin
    docker compose version
    log "Docker Compose 插件安装完成"
  fi
}

install_nginx() {
  if command -v nginx >/dev/null 2>&1; then
    warn "检测到 Nginx 已经安装，跳过 Nginx 安装"
    nginx -v || true
  else
    info "安装 Nginx..."
    apt update
    apt install -y nginx
    log "Nginx 安装完成"
  fi

  systemctl enable nginx
  systemctl start nginx

  nginx -t
  log "Nginx 已启动并通过配置检查"
}

show_basic_commands() {
  cat <<'EOF'

============================================================
常用命令速查
============================================================

查看正在运行的容器：
  docker ps

查看所有容器：
  docker ps -a

查看某个容器日志：
  docker logs -f 容器名

重启容器：
  docker restart 容器名

进入容器：
  docker exec -it 容器名 sh

进入项目目录后启动/更新：
  docker compose up -d

拉取最新镜像：
  docker compose pull

检查 Nginx 配置：
  nginx -t

重载 Nginx：
  systemctl reload nginx

============================================================

EOF
}

create_docker_template() {
  if ! ask_yes_no "是否创建一个 Docker 服务模板目录？例如 s-ui / komari / oci-helper" "y"; then
    return
  fi

  read -rp "请输入服务名称（英文，例：s-ui、komari、oci-helper，可自定义）: " SERVICE_NAME
  while ! safe_name "$SERVICE_NAME"; do
    err "服务名称只能包含英文、数字、点、横杠、下划线，不能有中文或空格"
    read -rp "请重新输入服务名称: " SERVICE_NAME
  done

  read -rp "请输入服务统一存放目录（默认 /opt/docker-apps）: " BASE_DIR
  BASE_DIR="${BASE_DIR:-/opt/docker-apps}"

  APP_DIR="${BASE_DIR}/${SERVICE_NAME}"

  mkdir -p "$APP_DIR"
  log "已创建目录：$APP_DIR"

  cat > "$APP_DIR/docker-compose.yml" <<EOF
services:
  ${SERVICE_NAME}:
    image: 请改成你的镜像名:latest
    container_name: ${SERVICE_NAME}
    restart: unless-stopped
    ports:
      # 格式说明：
      # "127.0.0.1:宿主机端口:容器端口" = 只允许本机访问，推荐给面板类服务
      # "宿主机端口:容器端口" = 暴露公网，谨慎使用
      - "127.0.0.1:8080:8080"
    volumes:
      # 左边是服务器目录，右边是容器内部目录
      # 这里是示例，具体路径要看项目官方文档
      - ./data:/app/data
EOF

  log "已生成 Docker Compose 模板：$APP_DIR/docker-compose.yml"
  warn "请先编辑 image、ports、volumes，再执行：cd $APP_DIR && docker compose up -d"
}

create_nginx_proxy() {
  if ! ask_yes_no "是否创建一个 Nginx 反向代理配置？" "y"; then
    return
  fi

  read -rp "请输入 Nginx 配置名称（英文，例：s-ui、komari、oci-helper，可自定义）: " SITE_NAME
  while ! safe_name "$SITE_NAME"; do
    err "配置名称只能包含英文、数字、点、横杠、下划线，不能有中文或空格"
    read -rp "请重新输入配置名称: " SITE_NAME
  done

  read -rp "请输入域名（例：app.example.com）: " DOMAIN
  while [ -z "$DOMAIN" ]; do
    err "域名不能为空"
    read -rp "请输入域名（例：app.example.com）: " DOMAIN
  done

  read -rp "请输入要反代到的本机端口（例：2095、25774、8818）: " TARGET_PORT
  while ! echo "$TARGET_PORT" | grep -Eq '^[0-9]+$'; do
    err "端口只能是数字"
    read -rp "请重新输入端口: " TARGET_PORT
  done

  SITE_FILE="/etc/nginx/sites-available/${SITE_NAME}"

  cat > "$SITE_FILE" <<EOF
server {
    listen 80;
    server_name ${DOMAIN};

    location / {
        proxy_pass http://127.0.0.1:${TARGET_PORT};

        proxy_http_version 1.1;

        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;

        # WebSocket 支持，很多面板、监控、VNC、终端服务都需要
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
EOF

  ln -sf "$SITE_FILE" "/etc/nginx/sites-enabled/${SITE_NAME}"

  if ask_yes_no "是否删除 Nginx 默认欢迎页配置？新服务器建议删除" "y"; then
    rm -f /etc/nginx/sites-enabled/default
  fi

  nginx -t
  systemctl reload nginx

  log "Nginx 反向代理已创建：${DOMAIN} -> 127.0.0.1:${TARGET_PORT}"
  warn "如果访问仍是 Nginx 欢迎页，检查 DNS 是否解析到本机 IP，以及 server_name 是否写对"
}

install_certbot() {
  if ! ask_yes_no "是否安装 Certbot 并申请 HTTPS 证书？" "n"; then
    return
  fi

  apt update
  apt install -y certbot python3-certbot-nginx

  read -rp "请输入要申请证书的域名（必须已解析到本服务器）: " CERT_DOMAIN
  while [ -z "$CERT_DOMAIN" ]; do
    err "域名不能为空"
    read -rp "请输入要申请证书的域名: " CERT_DOMAIN
  done

  certbot --nginx -d "$CERT_DOMAIN"

  log "证书申请流程执行完成"
  warn "可以执行 certbot renew --dry-run 测试自动续期"
}

open_firewall_basic() {
  if ! command -v ufw >/dev/null 2>&1; then
    warn "未检测到 ufw，跳过防火墙配置"
    return
  fi

  if ask_yes_no "是否用 UFW 放行 80 和 443？" "y"; then
    ufw allow 80/tcp
    ufw allow 443/tcp
    log "已放行 80/443"
  fi

  if ask_yes_no "是否现在启用 UFW？注意：如果你是 SSH 连接，请确保 SSH 端口已放行" "n"; then
    read -rp "请输入 SSH 端口（默认 22）: " SSH_PORT
    SSH_PORT="${SSH_PORT:-22}"
    ufw allow "${SSH_PORT}/tcp"
    ufw --force enable
    ufw status verbose
  else
    warn "未启用 UFW。如已启用，可手动执行 ufw status 查看规则"
  fi
}

main() {
  clear
  echo "============================================================"
  echo " Docker + Docker Compose Plugin + Nginx 交互安装脚本"
  echo " 支持：Debian / Ubuntu"
  echo "============================================================"
  echo

  need_root
  detect_os

  install_base_tools
  install_docker_repo
  install_compose_plugin_if_missing
  install_nginx
  open_firewall_basic
  create_docker_template
  create_nginx_proxy
  install_certbot
  show_basic_commands

  log "全部流程执行完成"
}

main "$@"
