#!/bin/bash

# ==================================================
# BBR 一键管理脚本
# 支持：默认版 BBR / 优化版 BBR / 状态查看 / 卸载恢复
# 适用：Debian / Ubuntu / Linux VPS
# ==================================================

VERSION="1.1.0"
AUTHOR="ning"

GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
BLUE="\033[36m"
NC="\033[0m"

info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

pause() {
    echo
    read -rp "按 Enter 返回菜单..."
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        error "请使用 root 权限运行"
        echo "示例：sudo bash bbr-f"
        exit 1
    fi
}

show_header() {
    clear
    echo "=================================================="
    echo " BBR 一键管理脚本 v${VERSION}"
    echo " Author: ${AUTHOR}"
    echo "=================================================="
}

show_status() {
    echo
    echo "当前状态："
    echo "--------------------------------------------------"
    echo "内核版本：$(uname -r)"
    echo "系统信息：$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '\"')"
    echo "拥塞算法：$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)"
    echo "队列算法：$(sysctl -n net.core.default_qdisc 2>/dev/null)"
    echo "可用算法：$(sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null)"
    echo "模块状态：$(lsmod | grep -q tcp_bbr && echo 已加载 || echo 未加载)"
    echo "--------------------------------------------------"

    if [ "$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)" = "bbr" ]; then
        success "BBR 已开启"
    else
        warn "当前未使用 BBR"
    fi

    if [ "$(sysctl -n net.core.default_qdisc 2>/dev/null)" = "fq" ]; then
        success "队列算法 fq 已开启"
    else
        warn "当前队列算法不是 fq"
    fi

    if ss -ti 2>/dev/null | grep -q "bbr"; then
        success "检测到当前已有连接正在使用 BBR"
    else
        warn "暂未检测到当前连接使用 BBR"
        echo "说明：BBR 只对新建立的 TCP 连接生效"
        echo "建议：重新连接 SSH 后再次检测"
    fi
}

clean_old_config() {
    sed -i '/# BBR Manager Start/,/# BBR Manager End/d' /etc/sysctl.conf
    sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
    sed -i '/net.core.rmem_max/d' /etc/sysctl.conf
    sed -i '/net.core.wmem_max/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_rmem/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_wmem/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_fastopen/d' /etc/sysctl.conf
    sed -i '/net.core.somaxconn/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_max_syn_backlog/d' /etc/sysctl.conf
    sed -i '/net.ipv4.ip_local_port_range/d' /etc/sysctl.conf
}

check_bbr_support() {
    modprobe tcp_bbr 2>/dev/null

    if ! lsmod | grep -q tcp_bbr; then
        error "BBR 模块加载失败，当前内核可能不支持 BBR"
        return 1
    fi

    if ! sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null | grep -q bbr; then
        error "系统可用算法中未检测到 bbr"
        return 1
    fi

    return 0
}

enable_bbr_default() {
    show_header
    info "正在开启 BBR 默认版..."
    echo
    echo "默认版说明："
    echo "- 只开启 BBR + fq"
    echo "- 稳定性最高"
    echo "- 适合大多数 VPS / 代理 / 日常使用"
    echo

    check_bbr_support || {
        pause
        return
    }

    clean_old_config

    cat >> /etc/sysctl.conf << EOF

# BBR Manager Start
# BBR 默认版：稳定推荐
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
# BBR Manager End
EOF

    grep -q "^tcp_bbr$" /etc/modules || echo "tcp_bbr" >> /etc/modules

    sysctl -p >/dev/null 2>&1

    if [ "$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)" = "bbr" ] && [ "$(sysctl -n net.core.default_qdisc 2>/dev/null)" = "fq" ]; then
        success "BBR 默认版开启成功"
        warn "请重新连接 SSH，让新连接使用 BBR"
    else
        error "BBR 默认版开启失败"
    fi

    pause
}

enable_bbr_optimized() {
    show_header
    info "正在开启 BBR 优化版..."
    echo
    echo "优化版说明："
    echo "- 在默认版基础上增加 TCP 参数优化"
    echo "- 适合跨境、高延迟、大带宽、代理/中转场景"
    echo "- 稳定性仍然较高，但比默认版参数更多"
    echo

    check_bbr_support || {
        pause
        return
    }

    clean_old_config

    cat >> /etc/sysctl.conf << EOF

# BBR Manager Start
# BBR 优化版：适合跨境 / 高延迟 / 大带宽

# Enable BBR
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr

# TCP Buffer Optimization
net.core.rmem_max=67108864
net.core.wmem_max=67108864
net.ipv4.tcp_rmem=4096 87380 67108864
net.ipv4.tcp_wmem=4096 65536 67108864

# TCP Fast Open
net.ipv4.tcp_fastopen=3

# Connection Queue Optimization
net.core.somaxconn=4096
net.ipv4.tcp_max_syn_backlog=4096

# Local Port Range
net.ipv4.ip_local_port_range=10240 65535
# BBR Manager End
EOF

    grep -q "^tcp_bbr$" /etc/modules || echo "tcp_bbr" >> /etc/modules

    sysctl -p >/dev/null 2>&1

    if [ "$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)" = "bbr" ] && [ "$(sysctl -n net.core.default_qdisc 2>/dev/null)" = "fq" ]; then
        success "BBR 优化版开启成功"
        warn "请重新连接 SSH，让新连接使用 BBR"
    else
        error "BBR 优化版开启失败"
    fi

    pause
}

uninstall_bbr() {
    show_header
    warn "即将卸载 BBR 配置，并恢复为 cubic"

    read -rp "确认卸载？输入 y 继续：" confirm

    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        warn "已取消"
        pause
        return
    fi

    clean_old_config
    sed -i '/^tcp_bbr$/d' /etc/modules

    cat >> /etc/sysctl.conf << EOF

# BBR Manager Start
# Restore default congestion control
net.core.default_qdisc=fq_codel
net.ipv4.tcp_congestion_control=cubic
# BBR Manager End
EOF

    sysctl -p >/dev/null 2>&1

    success "已恢复为 cubic"
    warn "建议重新连接 SSH 或重启服务器后确认状态"

    pause
}

menu() {
    while true; do
        show_header
        echo "请选择操作："
        echo
        echo "1. 开启 BBR 默认版"
        echo "   说明：最稳定，只开启 BBR + fq，适合大多数 VPS"
        echo
        echo "2. 开启 BBR 优化版"
        echo "   说明：默认版 + TCP 优化，适合跨境 / 高延迟 / 大带宽"
        echo
        echo "3. 查看当前状态"
        echo "   说明：查看 BBR 是否开启、当前连接是否使用 BBR"
        echo
        echo "4. 卸载 BBR / 恢复默认"
        echo "   说明：恢复为 cubic + fq_codel"
        echo
        echo "0. 退出"
        echo
        read -rp "请输入数字：" choice

        case "$choice" in
            1) enable_bbr_default ;;
            2) enable_bbr_optimized ;;
            3) show_header; show_status; pause ;;
            4) uninstall_bbr ;;
            0) exit 0 ;;
            *) warn "无效输入，请重新选择"; sleep 1 ;;
        esac
    done
}

check_root
menu