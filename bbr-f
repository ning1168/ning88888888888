#!/bin/bash

VERSION="1.2.0"

GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
BLUE="\033[36m"
NC="\033[0m"

info(){ echo -e "${BLUE}[INFO]${NC} $1"; }
success(){ echo -e "${GREEN}[OK]${NC} $1"; }
warn(){ echo -e "${YELLOW}[WARN]${NC} $1"; }
error(){ echo -e "${RED}[ERR]${NC} $1"; }

pause(){ read -rp "按回车返回..." ; }

check_root(){
    [ "$EUID" -ne 0 ] && { error "请用 root 运行"; exit 1; }
}

show_header(){
    clear
    echo "=================================="
    echo " BBR 管理脚本 v${VERSION}"
    echo "=================================="
}

clean(){
    sed -i '/# BBR Manager Start/,/# BBR Manager End/d' /etc/sysctl.conf
}

detect_mode(){
    cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
    rmem=$(sysctl -n net.core.rmem_max 2>/dev/null)

    if [ "$cc" != "bbr" ]; then
        echo "未开启"
        return
    fi

    if [ "$rmem" = "67108864" ]; then
        echo "优化版"
    else
        echo "默认版"
    fi
}

show_status(){
    echo
    echo "内核: $(uname -r)"
    echo "拥塞: $(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)"
    echo "队列: $(sysctl -n net.core.default_qdisc 2>/dev/null)"
    echo "模式: $(detect_mode)"
    echo

    if ss -ti | grep -q bbr; then
        success "连接中已使用 BBR"
    else
        warn "当前连接未使用 BBR（需新连接）"
    fi
}

enable_default(){
    show_header
    info "开启 BBR（默认版）"

    modprobe tcp_bbr || { error "不支持 BBR"; pause; return; }

    clean

    cat >> /etc/sysctl.conf <<EOF

# BBR Manager Start
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
# BBR Manager End
EOF

    sysctl -p >/dev/null

    success "已开启（默认版）"
    pause
}

enable_opt(){
    show_header
    info "开启 BBR（优化版）"

    modprobe tcp_bbr || { error "不支持 BBR"; pause; return; }

    clean

    cat >> /etc/sysctl.conf <<EOF

# BBR Manager Start
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr

net.core.rmem_max=67108864
net.core.wmem_max=67108864
net.ipv4.tcp_rmem=4096 87380 67108864
net.ipv4.tcp_wmem=4096 65536 67108864

net.ipv4.tcp_fastopen=3
net.core.somaxconn=4096
net.ipv4.tcp_max_syn_backlog=4096
# BBR Manager End
EOF

    sysctl -p >/dev/null

    success "已开启（优化版）"
    pause
}

uninstall(){
    show_header
    warn "恢复默认 cubic"

    clean

    cat >> /etc/sysctl.conf <<EOF

# BBR Manager Start
net.core.default_qdisc=fq_codel
net.ipv4.tcp_congestion_control=cubic
# BBR Manager End
EOF

    sysctl -p >/dev/null

    success "已恢复"
    pause
}

menu(){
    while true; do
        show_header
        echo "1. 开启 BBR（默认）"
        echo "2. 开启 BBR（优化）"
        echo "3. 查看状态"
        echo "4. 卸载 BBR"
        echo "0. 退出"
        echo
        read -rp "选择: " c

        case $c in
            1) enable_default ;;
            2) enable_opt ;;
            3) show_header; show_status; pause ;;
            4) uninstall ;;
            0) exit ;;
            *) warn "无效输入"; sleep 1 ;;
        esac
    done
}

check_root
menu