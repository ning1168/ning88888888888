#!/bin/bash

# ==================================================
# BBR 一键管理脚本
# 支持：BBR / BBRv2检测 / TCP优化 / 卸载恢复 / 状态查看
# 适用：Debian / Ubuntu / Linux VPS
# ==================================================

VERSION="1.0.0"
AUTHOR="ning"

GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
BLUE="\033[36m"
NC="\033[0m"

info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

pause() {
    echo
    read -rp "按 Enter 返回菜单..."
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        error "请使用 root 权限运行"
        echo "示例：sudo bash bbr-f"
        exit 1
    fi
}

show_header() {
    clear
    echo "=================================================="
    echo " BBR 一键管理脚本 v${VERSION}"
    echo " Author: ${AUTHOR}"
    echo "=================================================="
}

show_status() {
    echo
    echo "系统状态："
    echo "--------------------------------------------------"
    echo "内核版本：$(uname -r)"
    echo "系统信息：$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '\"')"
    echo "当前拥塞算法：$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)"
    echo "当前队列算法：$(sysctl -n net.core.default_qdisc 2>/dev/null)"
    echo "可用拥塞算法：$(sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null)"
    echo "BBR 模块状态：$(lsmod | grep -q tcp_bbr && echo 已加载 || echo 未加载)"
    echo "--------------------------------------------------"

    if sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "^bbr"; then
        success "BBR 已配置为当前拥塞控制算法"
    else
        warn "当前未使用 BBR"
    fi

    if ss -ti 2>/dev/null | grep -q "bbr"; then
        success "检测到当前已有连接正在使用 BBR"
    else
        warn "暂未检测到当前连接使用 BBR"
        echo "说明：BBR 只对新建立的 TCP 连接生效"
    fi

    if sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null | grep -q "bbr2"; then
        success "当前系统支持 BBRv2"
    else
        warn "当前系统未检测到 BBRv2"
    fi
}

clean_old_config() {
    sed -i '/# BBR Manager Start/,/# BBR Manager End/d' /etc/sysctl.conf
    sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
    sed -i '/net.core.rmem_max/d' /etc/sysctl.conf
    sed -i '/net.core.wmem_max/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_rmem/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_wmem/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_fastopen/d' /etc/sysctl.conf
    sed -i '/net.core.somaxconn/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_max_syn_backlog/d' /etc/sysctl.conf
    sed -i '/net.ipv4.ip_local_port_range/d' /etc/sysctl.conf
}

enable_bbr() {
    show_header
    info "开始开启 BBR..."

    modprobe tcp_bbr 2>/dev/null

    if ! lsmod | grep -q tcp_bbr; then
        error "BBR 模块加载失败，当前内核可能不支持 BBR"
        pause
        return
    fi

    clean_old_config

    cat >> /etc/sysctl.conf << EOF

# BBR Manager Start
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
# BBR Manager End
EOF

    grep -q "^tcp_bbr$" /etc/modules || echo "tcp_bbr" >> /etc/modules

    sysctl -p >/dev/null 2>&1

    if [ "$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)" = "bbr" ]; then
        success "BBR 开启成功"
        warn "请重新连接 SSH，让新连接使用 BBR"
    else
        error "BBR 开启失败"
    fi

    pause
}

enable_bbr_optimized() {
    show_header
    info "开始开启 BBR + TCP 优化..."

    modprobe tcp_bbr 2>/dev/null

    if ! lsmod | grep -q tcp_bbr; then
        error "BBR 模块加载失败，当前内核可能不支持 BBR"
        pause
        return
    fi

    clean_old_config

    cat >> /etc/sysctl.conf << EOF

# BBR Manager Start
# Enable BBR
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr

# TCP Buffer Optimization
net.core.rmem_max=67108864
net.core.wmem_max=67108864
net.ipv4.tcp_rmem=4096 87380 67108864
net.ipv4.tcp_wmem=4096 65536 67108864

# TCP Fast Open
net.ipv4.tcp_fastopen=3

# Connection Queue Optimization
net.core.somaxconn=4096
net.ipv4.tcp_max_syn_backlog=4096

# Local Port Range
net.ipv4.ip_local_port_range=10240 65535
# BBR Manager End
EOF

    grep -q "^tcp_bbr$" /etc/modules || echo "tcp_bbr" >> /etc/modules

    sysctl -p >/dev/null 2>&1

    if [ "$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)" = "bbr" ]; then
        success "BBR + TCP 优化开启成功"
        warn "请重新连接 SSH，让新连接使用 BBR"
    else
        error "优化配置失败"
    fi

    pause
}

enable_bbr2() {
    show_header
    info "检测 BBRv2 支持情况..."

    available=$(sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null)

    if echo "$available" | grep -q "bbr2"; then
        success "检测到系统支持 BBRv2"

        clean_old_config

        cat >> /etc/sysctl.conf << EOF

# BBR Manager Start
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr2
# BBR Manager End
EOF

        sysctl -p >/dev/null 2>&1

        if [ "$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)" = "bbr2" ]; then
            success "BBRv2 开启成功"
        else
            error "BBRv2 设置失败"
        fi
    else
        warn "当前系统不支持 BBRv2"
        echo "说明：BBRv2 通常需要特定内核支持，不是所有系统默认都有"
        echo "建议：普通用户使用 BBR 即可，稳定性更好"
    fi

    pause
}

uninstall_bbr() {
    show_header
    warn "即将卸载 BBR 配置，并恢复默认 cubic"

    read -rp "确认卸载？输入 y 继续：" confirm

    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        warn "已取消"
        pause
        return
    fi

    clean_old_config
    sed -i '/^tcp_bbr$/d' /etc/modules

    cat >> /etc/sysctl.conf << EOF

# BBR Manager Start
net.core.default_qdisc=fq_codel
net.ipv4.tcp_congestion_control=cubic
# BBR Manager End
EOF

    sysctl -p >/dev/null 2>&1

    success "已恢复为 cubic"
    warn "如需完全恢复旧连接状态，建议重启服务器"

    pause
}

menu() {
    while true; do
        show_header
        echo "请选择操作："
        echo
        echo "1. 开启 BBR（稳定推荐）"
        echo "2. 开启 BBR + TCP 优化（跨境/高延迟推荐）"
        echo "3. 尝试开启 BBRv2（高级/需内核支持）"
        echo "4. 查看当前状态"
        echo "5. 卸载 BBR / 恢复默认"
        echo "0. 退出"
        echo
        read -rp "请输入数字：" choice

        case "$choice" in
            1) enable_bbr ;;
            2) enable_bbr_optimized ;;
            3) enable_bbr2 ;;
            4) show_header; show_status; pause ;;
            5) uninstall_bbr ;;
            0) exit 0 ;;
            *) warn "无效输入"; sleep 1 ;;
        esac
    done
}

check_root
menu