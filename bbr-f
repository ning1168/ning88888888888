#!/bin/bash

# Debian 12 BBR 一键开启 / 状态检测脚本

GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
NC="\033[0m"

check_bbr() {
    current_cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
    current_qdisc=$(sysctl -n net.core.default_qdisc 2>/dev/null)

    if [ "$current_cc" = "bbr" ] && [ "$current_qdisc" = "fq" ]; then
        return 0
    else
        return 1
    fi
}

show_status() {
    echo
    echo "当前状态："
    echo "内核版本：$(uname -r)"
    echo "拥塞算法：$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)"
    echo "队列算法：$(sysctl -n net.core.default_qdisc 2>/dev/null)"
}

echo "================================"
echo " Debian 12 BBR 检测 / 开启脚本"
echo "================================"

if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}请使用 root 权限运行：sudo bash bbr-f${NC}"
    exit 1
fi

show_status

if check_bbr; then
    echo
    echo -e "${GREEN}BBR 已配置成功，无需重复开启。${NC}"

    if ss -ti | grep -q "bbr"; then
        echo -e "${GREEN}检测到当前已有连接正在使用 BBR。${NC}"
    else
        echo -e "${YELLOW}暂未检测到当前连接使用 BBR。${NC}"
        echo "说明：BBR 只对新建立的 TCP 连接生效。"
        echo "建议：重新连接 SSH 后，再次运行本脚本检测。"
    fi

    exit 0
fi

echo
echo -e "${YELLOW}BBR 尚未完整启用，开始配置...${NC}"

echo "加载 BBR 模块..."
modprobe tcp_bbr 2>/dev/null

if ! lsmod | grep -q "tcp_bbr"; then
    echo -e "${RED}BBR 模块加载失败，系统可能不支持 BBR。${NC}"
    exit 1
fi

echo "写入系统配置..."

sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf

cat >> /etc/sysctl.conf << EOF

# Enable BBR
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
EOF

grep -q "^tcp_bbr$" /etc/modules || echo "tcp_bbr" >> /etc/modules

echo "应用配置..."
sysctl -p >/dev/null

echo
show_status

if check_bbr; then
    echo
    echo -e "${GREEN}BBR 开启成功。${NC}"
    echo "提示：请重新连接 SSH，让新连接使用 BBR。"
else
    echo
    echo -e "${RED}BBR 开启失败，请检查系统内核或权限。${NC}"
    exit 1
fi