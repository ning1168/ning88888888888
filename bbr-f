#!/bin/bash

# Debian 12 BBR 一键开启 + 状态检测脚本
# 适用于 VPS / 云服务器

echo "=============================="
echo " Debian 12 BBR 检测与开启脚本"
echo "=============================="

# 必须使用 root 权限
if [ "$EUID" -ne 0 ]; then
    echo "请使用 root 权限运行："
    echo "sudo bash bbr.sh"
    exit 1
fi

echo
echo "当前内核版本："
uname -r

echo
echo "当前拥塞控制算法："
sysctl net.ipv4.tcp_congestion_control

echo
echo "检测 BBR 模块..."

# 尝试加载 BBR 模块
modprobe tcp_bbr 2>/dev/null

if lsmod | grep -q "tcp_bbr"; then
    echo "BBR 模块已加载"
else
    echo "BBR 模块加载失败，当前系统可能不支持 BBR"
    exit 1
fi

echo
echo "写入 BBR 配置..."

# 删除旧的重复配置，避免多次运行重复写入
sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf

cat >> /etc/sysctl.conf << EOF

# Enable BBR
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
EOF

# 设置开机自动加载 tcp_bbr
grep -q "^tcp_bbr$" /etc/modules || echo "tcp_bbr" >> /etc/modules

echo
echo "应用系统配置..."
sysctl -p

echo
echo "最终检测结果："

current_cc=$(sysctl -n net.ipv4.tcp_congestion_control)
current_qdisc=$(sysctl -n net.core.default_qdisc)

if [ "$current_cc" = "bbr" ] && [ "$current_qdisc" = "fq" ]; then
    echo "BBR 配置成功"
else
    echo "BBR 配置未完全成功"
    echo "当前拥塞控制算法：$current_cc"
    echo "当前队列算法：$current_qdisc"
    exit 1
fi

echo
echo "检测当前连接是否已使用 BBR："

if ss -ti | grep -q "bbr"; then
    echo "当前已有连接正在使用 BBR"
else
    echo "暂未检测到正在使用 BBR 的连接"
    echo "说明：BBR 只对新建立的 TCP 连接生效"
    echo "建议：重新连接 SSH，或等待新连接建立后再运行本脚本检测"
fi

echo
echo "=============================="
echo "完成"
echo "再次运行本脚本，可查看 BBR 是否生效"
echo "=============================="