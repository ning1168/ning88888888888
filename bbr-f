#!/bin/bash

VERSION="1.3.0"

GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
BLUE="\033[36m"
NC="\033[0m"

info(){ echo -e "${BLUE}[INFO]${NC} $1"; }
success(){ echo -e "${GREEN}[OK]${NC} $1"; }
warn(){ echo -e "${YELLOW}[WARN]${NC} $1"; }
error(){ echo -e "${RED}[ERR]${NC} $1"; }

pause(){ echo; read -rp "按回车返回..." ; }

check_root(){
    [ "$EUID" -ne 0 ] && { error "请用 root 运行"; exit 1; }
}

show_header(){
    clear
    echo "=================================="
    echo " BBR + Swap 管理脚本 v${VERSION}"
    echo "=================================="
}

clean_bbr(){
    sed -i '/# BBR Manager Start/,/# BBR Manager End/d' /etc/sysctl.conf
    sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
    sed -i '/net.core.rmem_max/d' /etc/sysctl.conf
    sed -i '/net.core.wmem_max/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_rmem/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_wmem/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_fastopen/d' /etc/sysctl.conf
    sed -i '/net.core.somaxconn/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_max_syn_backlog/d' /etc/sysctl.conf
}

detect_bbr_mode(){
    cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
    qdisc=$(sysctl -n net.core.default_qdisc 2>/dev/null)
    rmem=$(sysctl -n net.core.rmem_max 2>/dev/null)
    tfo=$(sysctl -n net.ipv4.tcp_fastopen 2>/dev/null)

    if [ "$cc" != "bbr" ]; then
        echo "未开启"
        return
    fi

    if [ "$qdisc" != "fq" ]; then
        echo "未完整开启"
        return
    fi

    if [ "$rmem" = "67108864" ] || [ "$tfo" = "3" ]; then
        echo "优化版"
    else
        echo "默认版"
    fi
}

show_bbr_status(){
    show_header

    cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
    qdisc=$(sysctl -n net.core.default_qdisc 2>/dev/null)
    tfo=$(sysctl -n net.ipv4.tcp_fastopen 2>/dev/null)

    echo
    echo "内核: $(uname -r)"
    echo "拥塞: ${cc:-未知}"
    echo "队列: ${qdisc:-未知}"
    echo "TFO : ${tfo:-未知}"
    echo "模式: $(detect_bbr_mode)"
    echo

    if [ "$cc" = "bbr" ] && [ "$qdisc" = "fq" ]; then
        success "BBR 已开启并生效"
    else
        warn "BBR 未完整开启"
    fi

    echo
    echo "连接检测: 仅供参考"
    if ss -ti 2>/dev/null | grep -q "bbr"; then
        success "检测到部分连接显示 BBR"
    else
        warn "当前连接未显示 BBR，不代表 BBR 未生效"
    fi

    echo
    echo "说明: 判断是否开启成功，以“拥塞=bbr、队列=fq”为准"
}

check_bbr_support(){
    modprobe tcp_bbr 2>/dev/null

    if ! lsmod | grep -q tcp_bbr; then
        error "BBR 模块加载失败，当前内核可能不支持 BBR"
        return 1
    fi

    if ! sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null | grep -q bbr; then
        error "系统可用算法中未检测到 bbr"
        return 1
    fi

    return 0
}

enable_bbr_default(){
    show_header
    info "开启 BBR 默认版"

    check_bbr_support || {
        pause
        return
    }

    clean_bbr

    cat >> /etc/sysctl.conf <<EOF

# BBR Manager Start
# BBR 默认版
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
# BBR Manager End
EOF

    grep -q "^tcp_bbr$" /etc/modules || echo "tcp_bbr" >> /etc/modules

    sysctl -p >/dev/null 2>&1

    cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
    qdisc=$(sysctl -n net.core.default_qdisc 2>/dev/null)

    if [ "$cc" = "bbr" ] && [ "$qdisc" = "fq" ]; then
        success "BBR 默认版开启成功"
    else
        error "BBR 默认版开启失败"
    fi

    pause
}

enable_bbr_opt(){
    show_header
    info "开启 BBR 优化版"

    check_bbr_support || {
        pause
        return
    }

    clean_bbr

    cat >> /etc/sysctl.conf <<EOF

# BBR Manager Start
# BBR 优化版
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr

# TCP Buffer
net.core.rmem_max=67108864
net.core.wmem_max=67108864
net.ipv4.tcp_rmem=4096 87380 67108864
net.ipv4.tcp_wmem=4096 65536 67108864

# TCP Fast Open
net.ipv4.tcp_fastopen=3

# Connection Queue
net.core.somaxconn=4096
net.ipv4.tcp_max_syn_backlog=4096
# BBR Manager End
EOF

    grep -q "^tcp_bbr$" /etc/modules || echo "tcp_bbr" >> /etc/modules

    sysctl -p >/dev/null 2>&1

    cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
    qdisc=$(sysctl -n net.core.default_qdisc 2>/dev/null)

    if [ "$cc" = "bbr" ] && [ "$qdisc" = "fq" ]; then
        success "BBR 优化版开启成功"
    else
        error "BBR 优化版开启失败"
    fi

    pause
}

uninstall_bbr(){
    show_header
    warn "卸载 BBR，并恢复 cubic"

    read -rp "确认卸载？输入 y 继续: " confirm

    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        warn "已取消"
        pause
        return
    fi

    clean_bbr
    sed -i '/^tcp_bbr$/d' /etc/modules

    cat >> /etc/sysctl.conf <<EOF

# BBR Manager Start
# Restore Default
net.core.default_qdisc=fq_codel
net.ipv4.tcp_congestion_control=cubic
# BBR Manager End
EOF

    sysctl -p >/dev/null 2>&1

    success "已恢复为 cubic"
    pause
}

recommend_swap_size(){
    mem_mb=$(free -m | awk '/Mem:/ {print $2}')

    if [ "$mem_mb" -le 512 ]; then
        echo "1G"
    elif [ "$mem_mb" -le 1024 ]; then
        echo "2G"
    elif [ "$mem_mb" -le 2048 ]; then
        echo "2G"
    else
        echo "1G"
    fi
}

show_swap_status(){
    show_header
    echo
    echo "内存 / Swap 状态:"
    echo "----------------------------------"
    free -h
    echo
    echo "Swap 文件:"
    echo "----------------------------------"
    swapon --show
    echo

    if swapon --show | grep -q "/swapfile"; then
        success "Swap 已开启"
    else
        warn "未检测到 /swapfile"
    fi
}

remove_swap_config(){
    sed -i '/# Swap Manager Start/,/# Swap Manager End/d' /etc/sysctl.conf
    sed -i '/vm.swappiness/d' /etc/sysctl.conf
    sed -i '/vm.vfs_cache_pressure/d' /etc/sysctl.conf
    sed -i '\|^/swapfile|d' /etc/fstab
}

create_swap(){
    show_header

    recommended=$(recommend_swap_size)

    echo "创建 / 重建 Swap"
    echo
    echo "检测到当前内存:"
    free -h | awk '/Mem:/ {print "内存: "$2}'
    echo
    echo "推荐 Swap 大小: $recommended"
    echo

    read -rp "请输入 Swap 大小 [默认 $recommended]: " swap_size
    swap_size=${swap_size:-$recommended}

    if ! echo "$swap_size" | grep -Eq '^[0-9]+[GgMm]$'; then
        error "格式错误，请输入 1G / 2G / 512M 这种格式"
        pause
        return
    fi

    if [ -f /swapfile ] || swapon --show | grep -q "/swapfile"; then
        warn "检测到已有 /swapfile，将先删除"
        swapoff /swapfile 2>/dev/null
        rm -f /swapfile
    fi

    remove_swap_config

    info "正在创建 ${swap_size} Swap 文件"

    if command -v fallocate >/dev/null 2>&1; then
        fallocate -l "$swap_size" /swapfile 2>/dev/null
    fi

    if [ ! -s /swapfile ]; then
        size_num=$(echo "$swap_size" | sed 's/[GgMm]//g')
        size_unit=$(echo "$swap_size" | sed 's/[0-9]//g' | tr 'a-z' 'A-Z')

        if [ "$size_unit" = "G" ]; then
            count=$((size_num * 1024))
        else
            count=$size_num
        fi

        dd if=/dev/zero of=/swapfile bs=1M count="$count" status=progress
    fi

    chmod 600 /swapfile
    mkswap /swapfile >/dev/null 2>&1
    swapon /swapfile

    if ! swapon --show | grep -q "/swapfile"; then
        error "Swap 开启失败"
        pause
        return
    fi

    echo "/swapfile none swap sw 0 0" >> /etc/fstab

    cat >> /etc/sysctl.conf <<EOF

# Swap Manager Start
vm.swappiness=10
vm.vfs_cache_pressure=50
# Swap Manager End
EOF

    sysctl -p >/dev/null 2>&1

    success "Swap 创建成功: $swap_size"
    echo
    free -h

    pause
}

delete_swap(){
    show_header
    warn "关闭并删除 /swapfile"

    read -rp "确认删除？输入 y 继续: " confirm

    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        warn "已取消"
        pause
        return
    fi

    swapoff /swapfile 2>/dev/null
    rm -f /swapfile
    remove_swap_config

    sysctl -p >/dev/null 2>&1

    success "Swap 已关闭并删除"
    pause
}

swap_menu(){
    while true; do
        show_header
        echo "Swap 管理"
        echo
        echo "1. 创建 / 重建 Swap"
        echo "2. 查看 Swap 状态"
        echo "3. 删除 Swap"
        echo "0. 返回主菜单"
        echo
        read -rp "选择: " s

        case "$s" in
            1) create_swap ;;
            2) show_swap_status; pause ;;
            3) delete_swap ;;
            0) return ;;
            *) warn "无效输入"; sleep 1 ;;
        esac
    done
}

main_menu(){
    while true; do
        show_header
        echo "1. 开启 BBR 默认版"
        echo "2. 开启 BBR 优化版"
        echo "3. Swap 虚拟内存管理"
        echo "4. 查看 BBR 状态"
        echo "5. 卸载 BBR"
        echo "0. 退出"
        echo
        read -rp "选择: " c

        case "$c" in
            1) enable_bbr_default ;;
            2) enable_bbr_opt ;;
            3) swap_menu ;;
            4) show_bbr_status; pause ;;
            5) uninstall_bbr ;;
            0) exit 0 ;;
            *) warn "无效输入"; sleep 1 ;;
        esac
    done
}

check_root
main_menu